---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Unicairn. Transportation data analytics.</p>
	<div class="social-links" aria-label="Social links">
		<a href="https://github.com/Ennazus" target="_blank" rel="noreferrer">GitHub</a>
		<a href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
		<a href="/rss.xml">RSS</a>
	</div>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: color-mix(in oklab, var(--ink-950), var(--ink-900) 50%);
		border-top: 1px solid color-mix(in oklab, var(--mint-400), transparent 75%);
		color: var(--ink-300);
		text-align: center;
	}
	p {
		margin: 0;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.8rem;
		margin-top: 1.1rem;
	}
	.social-links a {
		padding: 0.35rem 0.8rem;
		border: 1px solid color-mix(in oklab, var(--mint-400), transparent 70%);
		border-radius: 999px;
		text-decoration: none;
		color: var(--ink-50);
		font-size: 0.92rem;
	}
	.social-links a:hover {
		background: color-mix(in oklab, var(--mint-500), transparent 80%);
		color: var(--mint-100);
	}
</style>
