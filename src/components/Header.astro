---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { Image } from 'astro:assets';
import Logo from '../assets/unicairn_logo.png';
---

<header>
	<nav>
		<div class="brand-block">
			<div class="brand-row">
				<Image src={Logo} alt="Unicairn logo" width={32} height={32} class="brand-logo" />
				<h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>
			</div>
			<p class="tagline">Where transportation data becomes evidence</p>
		</div>
		<div class="internal-links" aria-label="Main navigation">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/work">Work</HeaderLink>
			<HeaderLink href="/research">Ideas</HeaderLink>
			<HeaderLink href="/resume">Resume</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="meta-links" aria-label="External links">
			<a href="https://github.com/Ennazus" target="_blank" rel="noreferrer">GitHub</a>
			<a href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(10px);
		background: color-mix(in oklab, var(--ink-950), transparent 24%);
		border-bottom: 1px solid color-mix(in oklab, var(--mint-400), transparent 75%);
	}
	.brand-block {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.brand-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.brand-logo {
		width: 32px;
		height: 32px;
		object-fit: contain;
		border-radius: 4px;
		flex-shrink: 0;
	}
	.brand {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.tagline {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		color: var(--ink-300);
		white-space: nowrap;
	}

	.brand a,
	.brand a.active {
		text-decoration: none;
		color: var(--mint-200);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.2rem;
		width: min(1100px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 68px;
	}
	.internal-links,
	.meta-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	nav a {
		padding: 0.5rem 0.75rem;
		font-size: 0.92rem;
		border: 1px solid transparent;
		border-radius: 999px;
		color: var(--ink-50);
		text-decoration: none;
		transition: border-color 200ms ease, color 200ms ease, background-color 200ms ease;
	}
	nav a.active {
		border-color: color-mix(in oklab, var(--mint-500), transparent 30%);
		background: color-mix(in oklab, var(--mint-500), transparent 82%);
		color: var(--mint-100);
	}
	nav a:hover {
		border-color: color-mix(in oklab, var(--mint-400), transparent 45%);
		color: var(--mint-100);
	}
	@media (max-width: 820px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
			padding: 0.6rem 0;
		}
		.brand {
			width: 100%;
			text-align: center;
		}
		.meta-links {
			display: none;
		}
	}
	@media (max-width: 480px) {
		nav a {
			padding: 0.45rem 0.65rem;
			font-size: 0.85rem;
		}
	}
</style>
