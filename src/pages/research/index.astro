---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('research')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Ideas | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1080px, calc(100% - 2rem));
			}
			h1 {
				margin-top: 0.8rem;
				margin-bottom: 1.6rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				grid-column: 1 / -1;
			}
			ul li:first-child img {
				width: 100%;
				height: min(420px, 38vw);
				object-fit: cover;
			}
			ul li:first-child .title {
				font-size: clamp(1.6rem, 2.7vw, 2.4rem);
			}
			ul li a {
				display: block;
				padding: 1rem;
				border-radius: 16px;
				border: 1px solid color-mix(in oklab, var(--mint-400), transparent 77%);
				background: color-mix(in oklab, var(--ink-900), transparent 18%);
			}
			ul li img {
				margin-bottom: 0.7rem;
				border-radius: 12px;
			}
			.title {
				margin: 0;
				color: var(--ink-0);
				line-height: 1.1;
				font-size: 1.18rem;
			}
			.date {
				margin: 0.65rem 0 0;
				color: var(--ink-200);
				font-size: 0.9rem;
			}
			ul li a:hover h2,
			ul li a:hover .date {
				color: var(--mint-100);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			ul li a:hover {
				border-color: color-mix(in oklab, var(--mint-300), transparent 54%);
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					gap: 0.7rem;
				}
				ul li:first-child {
					grid-column: auto;
				}
				ul li:first-child .title {
					font-size: 1.3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<h1>Ideas</h1>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/research/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h2 class="title">{post.data.title}</h2>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
