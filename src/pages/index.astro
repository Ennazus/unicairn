---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Headshot from '../assets/suzanne_headshot.JPG';
import Logo from '../assets/unicairn_logo.png';

const posts = (await getCollection('research'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="hero">
				<div class="hero-text">
					<p class="name">Suzanne Childress</p>
					<h1>Turning data into evidence planning agencies can act on.</h1>
					<p class="lead">
						20 years translating transportation data into decisions.					Translating messy transportation data into analysis that planning agencies can actually use — working collaboratively to drill down to the essentials, rigorous, interpretable, and connected to the decisions being made.						Available for consulting, research collaboration, and peer review.
					</p>
					<div class="hero-actions">
						<a class="button primary" href="/work">See my work</a>
						<a class="button secondary" href="/about">About Unicairn</a>
					</div>
				</div>
				<div class="hero-photo">
					<Image src={Headshot} alt="Suzanne Childress" width={220} height={220} class="headshot-img" />
				</div>
			</section>

			<section class="signal-panel" aria-label="Service areas">
				<article>
					<h2>Statistical, Surveys &amp; Modeling Expertise</h2>
					<p>Household travel survey design and successful application in planning, equity analytics, discrete choice model estimation, forecast evaluation, uncertainty quantification, and travel demand modeling (activity-based and trip-based). Two decades estimating, validating, and explaining models whose outputs directly shaped transit investment, long-range plans, and state legislation.</p>
				</article>
				<article>
					<h2>Data Systems &amp; Infrastructure</h2>
					<p>Data warehouse design, reproducible analytical workflows, and Python/R/SQL pipelines that give agencies lasting analytical independence. Experienced transitioning consultant-built systems into documented, maintainable in-house products and building open-source tools that make regional data accessible to planners.</p>
				</article>
				<article>
					<h2>Research &amp; Program Evaluation</h2>
					<p>Program design and management for large-scale research initiatives — from sampling strategy through public data dissemination — including leading multi-year, multi-million-dollar survey programs and building analytical teams. New technique development, AV/AI evaluation methodology, and translating findings into investment recommendations and policy-facing documents. Available for advisory, peer review, and strategic leadership roles.</p>
				</article>
			</section>

			<section class="latest" aria-label="Latest ideas">
				<div class="section-head">
					<h2>Latest ideas</h2>
					<a href="/research">See all</a>
				</div>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/research/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding-top: 3.5rem;
		animation: rise 520ms ease both;
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}
	.hero-text {
		flex: 1;
	}
	.hero-photo {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		flex-shrink: 0;
	}
	.logo-img {
		width: 140px;
		height: 140px;
		object-fit: contain;
		border-radius: 12px;
	}
	.headshot-img {
		width: 160px;
		height: 160px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center top;
		border: 2px solid color-mix(in oklab, var(--mint-400), transparent 60%);
	}
	@media (max-width: 600px) {
		.hero {
			flex-direction: column-reverse;
			align-items: flex-start;
			gap: 1.2rem;
		}
		.hero-photo {
			flex-direction: row;
			align-items: center;
		}
		.logo-img {
			width: 80px;
			height: 80px;
		}
		.headshot-img {
			width: 100px;
			height: 100px;
		}
	}
	.eyebrow {
		margin: 0;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--mint-200);
	}
	.name {
		margin: 0 0 0.3rem;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		color: var(--ink-0);
		letter-spacing: -0.02em;
		line-height: 1.1;
	}
	h1 {
		max-width: 20ch;
		margin-top: 0.4rem;
	}
	.lead {
		max-width: 64ch;
		color: var(--ink-100);
	}
	.hero-actions {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.72rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
		transition: transform 200ms ease, background-color 200ms ease;
	}
	.button:hover {
		transform: translateY(-1px);
	}
	.button.primary {
		background: var(--mint-500);
		color: var(--ink-950);
	}
	.button.secondary {
		border: 1px solid color-mix(in oklab, var(--mint-400), transparent 65%);
		color: var(--ink-0);
	}
	.signal-panel {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 3rem;
	}
	.signal-panel article {
		padding: 1.1rem;
		border-radius: 16px;
		background: color-mix(in oklab, var(--ink-900), transparent 15%);
		border: 1px solid color-mix(in oklab, var(--mint-500), transparent 80%);
		animation: rise 600ms ease both;
	}
	.signal-panel h2 {
		font-size: 1.1rem;
		margin: 0;
	}
	.signal-panel p {
		margin-bottom: 0;
		font-size: 0.95rem;
		color: var(--ink-200);
	}
	.latest {
		margin-top: 3.2rem;
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.section-head h2 {
		margin-bottom: 0.2rem;
	}
	.latest ul {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: grid;
		gap: 0.85rem;
	}
	.latest li a {
		display: block;
		padding: 1rem;
		border-radius: 14px;
		border: 1px solid color-mix(in oklab, var(--mint-400), transparent 78%);
		text-decoration: none;
		background: color-mix(in oklab, var(--ink-900), transparent 22%);
	}
	.latest li a:hover {
		border-color: color-mix(in oklab, var(--mint-300), transparent 56%);
	}
	.latest h3 {
		margin: 0;
		font-size: 1.05rem;
		color: var(--ink-0);
	}
	.latest p {
		margin: 0.45rem 0 0;
		color: var(--ink-200);
	}
	@media (max-width: 900px) {
		.signal-panel {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 720px) {
		.hero {
			padding-top: 2.1rem;
		}
		h1 {
			max-width: 100%;
		}
	}
</style>
